# Supabase
NEXT_PUBLIC_SUPABASE_URL=
# Supabase publishable key (sb_publishable_...). Replaces the legacy anon key.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# OpenRouter (server default key, quota-gated). BYOK is supplied per-user at runtime.
OPENROUTER_API_KEY=
OPENROUTER_DEFAULT_MODEL=openai/gpt-5.4-nano

# App
# Public base URL of the deployment. Used to build referral links and auth
# redirects; without it those fall back to the request origin, which behind a
# proxy is the internal address (localhost:3000). Set this to the real origin.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
